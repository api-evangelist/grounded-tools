        {
          "id": "641cd21e-3590-4af7-93e6-e2e869fadc63",
          "name": "Grounded.tools Send MCP message via streamable HTTP",
          "request": {
            "name": "Grounded.tools Send MCP message via streamable HTTP",
            "description": {
              "content": "Send a JSON-RPC 2.0 message to the MCP server over streamable HTTP. This is an alternative transport to SSE for MCP client connections. Supports all MCP protocol operations including tool invocations (scrape_docs, search_docs, fetch_url, list_libraries, find_version, list_jobs, get_job_info, cancel_job, remove_docs, refresh_version) and resource access.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "mcp"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"<string>\",\n  \"method\": \"<string>\",\n  \"id\": \"<string>\",\n  \"params\": {\n    \"name\": \"<string>\",\n    \"arguments\": \"<object>\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
